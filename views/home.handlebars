<section class="hero">

    <div class="hero-content">

        <h1>
            Luxury Nails,
            Exceptional Style
        </h1>

        <p>
            Professional nail care and beauty services
            tailored just for you.
        </p>

        <a
            href="/bookings"
            class="btn-primary"
        >
            Book Appointment
        </a>

    </div>

</section>

<section class="services">

    <h2>Our Services</h2>

    <div class="service-grid">

        {{#each services}}

            <div class="service-card">

                <h3>
                    {{service_name}}
                </h3>

                <p>
                    {{description}}
                </p>

                <div class="service-info">

                    <span>
                        R{{price}}
                    </span>

                    <span>
                        {{duration_minutes}} mins
                    </span>

                </div>

            </div>

        {{/each}}

    </div>

</section>

<section class="cta">

    <h2>
        Ready For Your Next Nail Appointment?
    </h2>

    <a
        href="/bookings"
        class="btn-primary"
    >
        Book Now
    </a>

</section>